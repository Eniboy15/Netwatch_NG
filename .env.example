# ─── PostgreSQL connection ───────────────────────────────────────
# Local PostgreSQL (default if you installed PostgreSQL directly)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=netwatch_ng
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── OR use a Supabase connection string (cloud option) ──────────
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ─── Server ──────────────────────────────────────────────────────
PORT=3001

# ─── OpenCelliD API key (kept here for future live queries) ──────
INGEST_API_KEY=replace_with_long_random_token
OPENCELLID_KEY=your_api_key_here
